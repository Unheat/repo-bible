# Database Configuration
DATABASE_URL="file:./dev.db"

# API Keys (Required)
# Get your OpenRouter API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=""

# Get your OpenAI API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=""

# Get your GitHub token from: https://github.com/settings/tokens
# Required scopes: repo (for private repos) or public_repo (for public repos only)
GITHUB_TOKEN=""

# Server Configuration
PORT=3000
NODE_ENV=development

# CORS Configuration
# Frontend URL for CORS (adjust if using different port)
FRONTEND_URL="http://localhost:5173"

# Optional: LLM Model Configuration
# Specify the model ID used for documentation generation
# Free models (containing 'free' in the name) will automatically use stricter rate limits
# LLM_MODEL_ID=deepseek/deepseek-v4-flash:free

# Optional: Deep-Dive Rate Limiting
# Override automatic rate limiting based on model type
# For free models: defaults to DEEPDIVE_CONCURRENCY=1, DEEPDIVE_DELAY_MS=3000
# For paid models: defaults to DEEPDIVE_CONCURRENCY=8, DEEPDIVE_DELAY_MS=0
# DEEPDIVE_CONCURRENCY=1
# DEEPDIVE_DELAY_MS=3000

# Optional: General Rate Limiting
# MAX_REQUESTS_PER_MINUTE=60

# Optional: Logging
# LOG_LEVEL=info